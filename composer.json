{
    "name": "xefi/laravel-passkey-api",
    "description": "A Laravel package for passkey authentication apis",
    "type": "library",
    "version": "0.2.0",
    "revision": "3",
    "license": "MIT",
    "authors": [
        {
            "name": "Xefi",
            "email": "contact@xefi.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "spomky-labs/cbor-php": "^3.0",
        "web-auth/cose-lib": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5|^12.0|^13.0",
        "orchestra/testbench": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Xefi\\LaravelPasskey\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Xefi\\LaravelPasskey\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Xefi\\LaravelPasskey\\PasskeyServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
